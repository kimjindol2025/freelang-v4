// ============================================================
// Array Functions (9)
// ============================================================

fn test_length(): void {
  var arr: [i32] = range(1, 6)
  var len: i32 = length(arr)
  println(str(len))  // Expected: 5
}

fn test_range(): void {
  var arr: [i32] = range(1, 4)
  println(str(length(arr)))  // Expected: 3
}

fn test_push(): void {
  var arr: [i32] = range(1, 3)
  push(arr, 3)
  println(str(length(arr)))  // Expected: 3
}

fn test_pop(): void {
  var arr: [i32] = range(1, 4)
  pop(arr)
  println(str(length(arr)))  // Expected: 2
}

fn test_slice(): void {
  var arr: [i32] = range(1, 6)
  var sliced: [i32] = slice(arr, 1, 4)
  println(str(length(sliced)))  // Expected: 3
}

fn test_reverse(): void {
  var arr: [i32] = range(1, 4)
  var rev: [i32] = reverse(arr)
  println(str(length(rev)))  // Expected: 3
}

fn test_sort(): void {
  println("✓ sort function")
}

fn test_unique(): void {
  println("✓ unique function")
}

fn test_clone(): void {
  var arr: [i32] = range(1, 3)
  var cloned: [i32] = clone(arr)
  println(str(length(cloned)))  // Expected: 2
}

// ============================================================
// String Functions (9)
// ============================================================

fn test_contains(): void {
  var s: string = "hello world"
  var found: bool = contains(s, "world")
  println(str(found))  // Expected: 1 (true)
}

fn test_split(): void {
  var s: string = "a,b,c"
  var parts: [string] = split(s, ",")
  println(str(length(parts)))  // Expected: 3
}

fn test_trim(): void {
  var s: string = "  hello  "
  var trimmed: string = trim(s)
  println(str(length(trimmed)))  // Expected: 5
}

fn test_to_upper(): void {
  var s: string = "hello"
  var upper: string = to_upper(s)
  println(upper)  // Expected: "HELLO"
}

fn test_to_lower(): void {
  var s: string = "HELLO"
  var lower: string = to_lower(s)
  println(lower)  // Expected: "hello"
}

fn test_char_at(): void {
  var s: string = "hello"
  var c: string = char_at(s, 1)
  println(c)  // Expected: "e"
}

fn test_starts_with(): void {
  var s: string = "hello world"
  var result: bool = starts_with(s, "hello")
  println(str(result))  // Expected: 1 (true)
}

fn test_ends_with(): void {
  var s: string = "hello world"
  var result: bool = ends_with(s, "world")
  println(str(result))  // Expected: 1 (true)
}

fn test_replace(): void {
  var s: string = "hello hello"
  var replaced: string = replace(s, "hello", "hi")
  println(replaced)  // Expected: "hi hi"
}

// ============================================================
// Math Functions (7)
// ============================================================

fn test_abs(): void {
  var result: i32 = abs(-5)
  println(str(result))  // Expected: 5
}

fn test_min(): void {
  var result: i32 = min(3, 7)
  println(str(result))  // Expected: 3
}

fn test_max(): void {
  var result: i32 = max(3, 7)
  println(str(result))  // Expected: 7
}

fn test_pow(): void {
  println("✓ pow function")
}

fn test_sqrt(): void {
  println("✓ sqrt function")
}

fn test_gcd(): void {
  var result: i32 = gcd(12, 8)
  println(str(result))  // Expected: 4
}

fn test_lcm(): void {
  var result: i32 = lcm(12, 8)
  println(str(result))  // Expected: 24
}

// ============================================================
// Cryptography Functions (6)
// ============================================================

fn test_md5(): void {
  var hash: string = md5("hello")
  println(hash)
}

fn test_sha256(): void {
  var hash: string = sha256("hello")
  println(str(length(hash)))  // Expected: 64
}

fn test_sha512(): void {
  var hash: string = sha512("hello")
  println(str(length(hash)))  // Expected: 128
}

fn test_base64_encode(): void {
  var encoded: string = base64_encode("hello")
  println(encoded)  // Expected: "aGVsbG8="
}

fn test_base64_decode(): void {
  println("✓ base64_decode function")
}

fn test_hmac(): void {
  var hash: string = hmac("hello", "secret")
  println(str(length(hash)))  // Expected: 64
}

