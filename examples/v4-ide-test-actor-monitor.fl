println("╚════════════════════════════════════════════════════╝")
println("")

test_actor_basic()
println("")

test_actor_sequence()
println("")

test_actor_bidirectional()
println("")

test_actor_fan_out()
println("")

test_actor_fan_in()
println("")

test_actor_pipeline()
println("")

test_actor_lifecycle()
println("")

test_actor_potential_deadlock()
println("")

test_actor_message_queue()
println("")

test_actor_state_machine()
println("")

